# ============================================================
# mcp-fadr-server — .gitignore
# ============================================================

# ----------------------------
# Environment / secrets
# ----------------------------
.env
.env.local
.env.*.local

# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------
# Virtual environments
# ----------------------------
.venv/
venv/
env/
ENV/

# ----------------------------
# Testing
# ----------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/

# ----------------------------
# Type checking
# ----------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ----------------------------
# Linting / formatting
# ----------------------------
.ruff_cache/

# ----------------------------
# Pre-commit
# ----------------------------
.pre-commit-db*

# ----------------------------
# IDEs
# ----------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----------------------------
# macOS
# ----------------------------
.DS_Store
.AppleDouble
.LSOverride

# ----------------------------
# Logs
# ----------------------------
*.log
logs/
