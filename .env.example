# ============================================================
# mcp-fadr-server — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ----------------------------
# Required
# ----------------------------

# Your Fadr API bearer token.
# Obtain at: https://fadr.com/settings/api
# Requires a Fadr Plus subscription.
FADR_API_KEY=your_fadr_api_key_here

# ----------------------------
# Optional — Fadr API
# ----------------------------

# Fadr API base URL. Change only if using a staging environment.
# Default: https://api.fadr.com
# FADR_BASE_URL=https://api.fadr.com

# HTTP request timeout in seconds for each individual Fadr API call.
# Default: 30
# FADR_TIMEOUT_S=30

# How often (in seconds) to poll the Fadr task status endpoint.
# Fadr recommends 5-second intervals. Minimum useful value: 2.
# Default: 5
# FADR_POLL_INTERVAL_S=5

# Maximum total time (in seconds) to wait for a Fadr task to complete.
# Stem separation of long tracks can take 60+ seconds.
# Default: 300
# FADR_POLL_TIMEOUT_S=300

# Number of retries on transient HTTP errors (429, 500, 502, 503, 504).
# Uses exponential backoff between retries.
# Default: 3
# FADR_MAX_RETRIES=3

# ----------------------------
# Optional — Input validation
# ----------------------------

# Comma-separated list of URL schemes allowed for audio_url inputs.
# Add http only if your audio host does not support HTTPS.
# Default: https
# ALLOWED_AUDIO_SCHEMES=https

# Maximum audio file size the server will download (in MB).
# Files exceeding this limit return an UPLOAD_FAILED error.
# Default: 100
# MAX_AUDIO_SIZE_MB=100

# ----------------------------
# Optional — Logging
# ----------------------------

# Log verbosity level. Use DEBUG for development, INFO for production.
# Allowed: DEBUG, INFO, WARNING, ERROR
# Default: INFO
# LOG_LEVEL=INFO
